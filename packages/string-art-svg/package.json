{
  "name": "@chthonic/string-art-svg",
  "type": "module",
  "version": "0.0.1",
  "description": "String art polygon SVG generator",
  "author": "Liam Myles",
  "license": "MIT",
  "homepage": "https://github.com/LiamMyles/pwp-packages/tree/main/packages/string-art-svg",
  "exports": {
    ".": "./dist/svg-generator.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "string-art-svg": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm run typecheck",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp --commit 'Release string-art-svg v'",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@chthonic/string-art": "workspace:*",
    "yargs": "^18.0.0"
  },
  "types": "./dist/svg-generator.d.cts"
}
